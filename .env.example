# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

BOT_ADMIN_ID=your_discord_user_id   # Receives DM alerts on delivery failures (optional)

# PostgreSQL
POSTGRES_USER=campus_lunch_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=campus_lunch

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # Required for halal menu image upload

# App
NODE_ENV=production
LOG_LEVEL=info
