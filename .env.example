# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

BOT_ADMIN_ID=your_discord_user_id   # Receives DM alerts on delivery failures (optional)

# PostgreSQL
POSTGRES_USER=campus_lunch_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=campus_lunch

# Uptime Kuma push monitors (optional — leave blank to disable)
# Create a "Push" monitor in Uptime Kuma, then paste its push URL here:
UPTIME_KUMA_HEARTBEAT_URL=   # bot pings this every 5 min (liveness check)
UPTIME_KUMA_MENU_PUSH_URL=   # bot pings this after daily menu delivery
HEALTH_PORT=3000              # port for /api/status health endpoint

# App
NODE_ENV=production
LOG_LEVEL=info
